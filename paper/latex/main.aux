\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Min-20\%++ leakage scores on 50 GENE-bench papers (eval) and 50 GeneTrace source papers (ref) per checkpoint. $\Delta $ = eval $-$ ref; negative $\Delta $ indicates the trained model is \emph  {less} confident on eval papers than on training-pool papers, the signature of no leakage. All trained checkpoints have $\Delta $ within $0.01$ of baseline, well below the $0.05$ threshold.\relax }}{7}{table.caption.35}\protected@file@percent }
\newlabel{tab:leakage}{{4}{7}{Min-20\%++ leakage scores on 50 GENE-bench papers (eval) and 50 GeneTrace source papers (ref) per checkpoint. $\Delta $ = eval $-$ ref; negative $\Delta $ indicates the trained model is \emph {less} confident on eval papers than on training-pool papers, the signature of no leakage. All trained checkpoints have $\Delta $ within $0.01$ of baseline, well below the $0.05$ threshold.\relax }{table.caption.35}{}}
